generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  username     String?        @unique
  profilePic   String?
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  mangaLibrary MangaLibrary[]
  progress     Progress[]
  ratings      Rating[]
  comments     Comment[]
}

model MangaLibrary {
  id        String   @id @default(uuid())
  userId    String
  mangaId   String   // ID from MangaDex
  status    String   // e.g., "READING", "PLANNING", "COMPLETED", "DROPPED", "ON_HOLD"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
}

model Progress {
  id           String   @id @default(uuid())
  userId       String
  mangaId      String   // ID from MangaDex
  chaptersRead Int      @default(0)
  volumesRead  Int      @default(0)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
}

model Rating {
  id        String   @id @default(uuid())
  userId    String
  mangaId   String   // ID from MangaDex
  score     Int      // 1 to 10
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  mangaId   String   // ID from MangaDex
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}